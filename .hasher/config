packager="`rpm --eval %packager`"
no_sisyphus_check="buildhost,gpg"
allowed_mountpoints=/dev/pts,/proc,/dev/shm,/dev,/sys
mount=/dev/pts,/proc
known_mountpoints=/proc,/dev/pts,/sys
lazy_cleanup=1
workdir="$HOME/hasher"
